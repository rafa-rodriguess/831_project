/**
 * pipeline_diagram.dot  -  DETAILED VIEW
 * =======================================
 * Full pipeline diagram for the paper:
 *   "From Clicks to Constructs: A Mixed-Methods Framework for
 *    Modeling Latent Student Engagement Using OULAD Data"
 *
 * Render:
 *   dot -Tpng pipeline_diagram.dot -o pipeline_diagram.png
 *   dot -Tsvg pipeline_diagram.dot -o pipeline_diagram.svg
 */

digraph pipeline_detailed {

    graph [
        rankdir   = TB
        fontname  = "Helvetica"
        fontsize  = 13
        splines   = polyline
        nodesep   = 0.55
        ranksep   = 0.70
        bgcolor   = "#FAFAFA"
        label     = "From Clicks to Constructs - Detailed Pipeline Architecture\n(OULAD Quantitative Strand  +  Synthetic Qualitative Strand  +  LE-JD Integration)"
        labelloc  = t
        labeljust = c
    ]

    node [
        fontname = "Helvetica"
        fontsize = 11
        style    = "filled,rounded"
        shape    = box
        margin   = "0.20,0.12"
    ]

    edge [
        fontname  = "Helvetica"
        fontsize  = 9
        color     = "#555555"
        arrowsize = 0.8
    ]

    /* === ROOT ============================================================ */

    proposal [
        label     = "proposal.md\n<Starting Point>\n\nFrom Clicks to Constructs:\nA Mixed-Methods Framework for Modeling\nLatent Student Engagement Using OULAD Data\n\n- 4 Research Questions (RQ1-RQ4)\n- Convergent Mixed-Methods Design\n- Latent Engagement Joint Display (LE-JD)\n- Appendix A: Q1-Q24 Interview Script\n- 6 Thematic Domains"
        shape     = note
        fillcolor = "#EAF4FB"
        color     = "#2471A3"
        penwidth  = 2
        fontsize  = 11
    ]

    /* === PIPELINE P - OULAD QUANTITATIVE STRAND ========================== */

    subgraph cluster_P {
        label     = "Pipeline P  -  OULAD Quantitative Strand  (src/)"
        style     = filled
        fillcolor = "#EBF5FB"
        color     = "#1A5276"
        penwidth  = 2
        fontsize  = 13
        fontcolor = "#1A5276"

        subgraph cluster_oulad_raw {
            label     = "OULAD Source Files  (read-only)"
            style     = dashed
            color     = "#5D6D7E"
            fillcolor = "#F2F3F4"
            fontsize  = 11

            studentVle [
                label     = "studentVle.csv\n(id_student, code_module,\ncode_presentation, date, sum_click)"
                fillcolor = "#D5F5E3"
                color     = "#1E8449"
            ]
            studentInfo [
                label     = "studentInfo.csv\n(age_band, gender, highest_education,\nimd_band, final_result,\nnum_of_prev_attempts, studied_credits)"
                fillcolor = "#D5F5E3"
                color     = "#1E8449"
            ]
            studentAssessment [
                label     = "studentAssessment.csv\n(score, date_submitted, is_banked)"
                fillcolor = "#D5F5E3"
                color     = "#1E8449"
            ]
            assessments_csv [
                label     = "assessments.csv\n(id_assessment, date,\nweight, assessment_type)"
                fillcolor = "#D5F5E3"
                color     = "#1E8449"
            ]
            courses_csv [
                label     = "courses.csv\n(module_presentation_length)"
                fillcolor = "#D5F5E3"
                color     = "#1E8449"
            ]
        }

        P0 [
            label     = "P0 - Foundation\n(P0_foundation.py)\n\n- Validates all 5 OULAD source files\n- Installs missing dependencies\n- Creates output directory tree\n- Writes environment_summary.json\n  and pipeline_audit.json"
            fillcolor = "#D6EAF8"
            color     = "#1A5276"
        ]

        duckdb [
            label     = "engagement.duckdb\n<Intermediate Database>\n\nTables created by P1:\n  raw_student_vle\n  raw_student_info\n  raw_student_assessment\n  raw_assessments\n  raw_courses"
            shape     = cylinder
            fillcolor = "#FDFEFE"
            color     = "#566573"
            fontsize  = 10
        ]

        P1 [
            label     = "P1 - Ingestion\n(P1_ingestion.py)\n\n- Loads 5 CSVs into DuckDB\n- Validates row counts and required columns\n- Appends per-table audit to pipeline_audit.json"
            fillcolor = "#D6EAF8"
            color     = "#1A5276"
        ]

        P2 [
            label     = "P2 - Panel Builder\n(P2_panel_builder.py)\n\n- Converts raw date (days) to week numbers\n- Aggregates clicks per enrollment x week\n  (total_clicks, active_days)\n- Fills zero-click weeks (complete grid)\n  Table: panel_base"
            fillcolor = "#D6EAF8"
            color     = "#1A5276"
        ]

        P3 [
            label     = "P3 - Engagement Indicators\n(P3_indicators.py)\n\n- Derives behavioral indicators:\n  log_clicks, click_intensity,\n  cumulative_clicks, recency,\n  streak, engagement_state {low|medium|high}\n  Table: panel_indicators"
            fillcolor = "#D6EAF8"
            color     = "#1A5276"
        ]

        P4 [
            label     = "P4 - Assessment Join\n(P4_assessment_join.py)\n\n- Joins student assessments with deadlines\n- Converts submission dates to week numbers\n- Computes assessment_score,\n  submission_timeliness,\n  has_assessment_this_week\n  Table: panel_with_assessment"
            fillcolor = "#D6EAF8"
            color     = "#1A5276"
        ]

        P5 [
            label     = "P5 - Demographics Join\n(P5_demographics_join.py)\n\n- Joins panel with studentInfo\n- Normalises final_result and imd_band\n- Validates no orphan enrollments\n  Table: panel_with_demographics\n  (+age_band, gender, highest_education,\n   imd_band, prev_attempts,\n   studied_credits, final_result)"
            fillcolor = "#D6EAF8"
            color     = "#1A5276"
        ]

        P6 [
            label     = "P6 - Validated Export\n(P6_export.py)\n\n- Selects final 22 columns\n- Checks NULLs, duplicates,\n  and invalid category values\n- Writes column_schema.json\n- Finalises pipeline_audit.json"
            fillcolor = "#D6EAF8"
            color     = "#1A5276"
        ]

        quant_csv [
            label     = "engagement_panel_weekly.csv\n<Final Quantitative Dataset>\n\nPerson x Week Panel  |  22 columns\nBehavioral: clicks, recency, streak,\n  log_clicks, click_intensity\nAssessment: score, timeliness\nDemographics: age, gender, education,\n  imd_band, studied_credits\nOutcome: engagement_state, final_result"
            shape     = note
            fillcolor = "#A9DFBF"
            color     = "#1E8449"
            penwidth  = 2
            fontsize  = 10
        ]
    }

    /* === PIPELINE S - SYNTHETIC QUALITATIVE STRAND ====================== */

    subgraph cluster_S {
        label     = "Pipeline S  -  Synthetic Qualitative Strand  (src_syntetic/)"
        style     = filled
        fillcolor = "#FEF9E7"
        color     = "#7D6608"
        penwidth  = 2
        fontsize  = 13
        fontcolor = "#7D6608"

        subgraph cluster_ext {
            label     = "External Datasets  (downloaded / placed manually)"
            style     = dashed
            color     = "#B7950B"
            fillcolor = "#FDFEFE"
            fontsize  = 11

            zenodo [
                label     = "Zenodo Dataset\n(merged_dataset.csv)\n14,003 rows x 16 cols  (int64, label-encoded)\nDOI: 10.5281/zenodo.16459132"
                fillcolor = "#FEF5E7"
                color     = "#D68910"
            ]
            kaggle [
                label     = "Kaggle Dataset\n(psychological_cbi_dataset.csv)\n1,300 rows x 19 cols  (mixed types)\nCC-BY 4.0"
                fillcolor = "#FEF5E7"
                color     = "#D68910"
            ]
        }

        S0 [
            label     = "S0 - External Data Ingestion\n(S0_ingest_external_sources.py)\n\n- Downloads Zenodo dataset via HTTP\n- Kaggle dataset via API or manual placement\n- SHA-256 checksum validation\n  Audit: s0_ingest_audit.json"
            fillcolor = "#FEF9E7"
            color     = "#7D6608"
        ]

        S1 [
            label     = "S1 - Decode and Normalize\n(S1_decode_and_normalize.py)\n\n- Decodes Zenodo columns (LabelEncoder -> text)\n- Normalizes 6 shared bridge constructs to [0,1]:\n  attendance, assignment, exam,\n  motivation, stress, discussion\n  zenodo_decoded.csv / kaggle_normalized.csv"
            fillcolor = "#FEF9E7"
            color     = "#7D6608"
        ]

        S2 [
            label     = "S2 - Cluster and Match\n(S2_cluster_and_map.py)\n\n- KMeans on 6 bridge constructs\n  (Zenodo and Kaggle independently)\n- NearestNeighbors: Kaggle->Zenodo (1-to-1)\n- Produces 1,300 matched persona pairs\n  zenodo_clustered.csv / kaggle_clustered.csv\n  persona_pairs.csv"
            fillcolor = "#FEF9E7"
            color     = "#7D6608"
        ]

        S3 [
            label     = "S3 - Persona Assembly\n(S3_persona_assembly.py)\n\n- Merges Kaggle + Zenodo columns per matched pair\n- Assigns one of 8 engagement archetypes:\n  Flourishing Achiever  /  Engaged but Pressured\n  Routine Complier  /  Resilient Climber\n  Disengaged Drifter  /  Overwhelmed Striver\n  Crisis Learner  /  Steady Performer\n  student_personas.csv  (1,300 x 37 cols)"
            fillcolor = "#FEF9E7"
            color     = "#7D6608"
        ]

        personas_csv [
            label     = "student_personas.csv\n1,300 personas x 37 columns\n(full profile + archetype label)"
            shape     = note
            fillcolor = "#FAD7A0"
            color     = "#7D6608"
            fontsize  = 10
        ]

        S4 [
            label     = "S4 - Interview Prompt Generation\n(S4_generate_prompts.py)\n\n- Embeds 24 interview questions from\n  proposal.md Appendix A (Q1-Q24)\n  across 6 thematic domains\n- Generates a unique international name\n  per persona (~25 nationalities, seeded)\n- Builds one-shot prompt per persona\n  student_personas_with_prompts.csv"
            fillcolor = "#FEF9E7"
            color     = "#7D6608"
        ]

        S5 [
            label     = "S5 - LLM Survey Execution\n(S5_run_llm_survey.py)\n\n- Anthropic Claude API (claude-opus-4-5)\n- 1,300 API calls  |  5 parallel workers\n- Resume-safe: skips existing JSON files\n- Exponential backoff (MAX_RETRIES=5)\n- JSON schema validation per response\n  llm_responses/P{id}.json  (1,300 files)\n  llm_survey_responses.csv"
            fillcolor = "#FADBD8"
            color     = "#922B21"
            penwidth  = 2
        ]

        claude_api [
            label     = "Anthropic Claude API\n(claude-opus-4-5)\n\nAnswers Q1-Q24 in first person\nas the student persona\n\nOutput JSON:\n  persona_id, Q1..Q24,\n  overall_engagement_self_assessment,\n  dominant_themes"
            shape     = component
            fillcolor = "#FDEDEC"
            color     = "#C0392B"
            fontsize  = 10
        ]

        llm_responses [
            label     = "llm_survey_responses.csv\n+  llm_responses/P{id}.json  (1,300 files)\n\nQ1-Q24 responses per persona\n(qualitative evidence strand)"
            shape     = note
            fillcolor = "#FAD7A0"
            color     = "#7D6608"
            fontsize  = 10
        ]

        S6 [
            label     = "S6 - Persona-Enrollment Bridge\n(S6_persona_enrollment_bridge.py)\n\n- Links each persona to up to 10\n  compatible OULAD enrollments\n- Hard filter: gender match\n- Weighted similarity score (0-1):\n    final_result  weight=3\n    engagement    weight=3\n    exam_score    weight=2\n    activity      weight=2\n- Minimum score threshold: 0.40\n  persona_enrollment_bridge.csv"
            fillcolor = "#FEF9E7"
            color     = "#7D6608"
        ]

        bridge_csv [
            label     = "persona_enrollment_bridge.csv\n(persona_id | enrollment_id\n | match_score | n_weeks | rank)"
            shape     = note
            fillcolor = "#FAD7A0"
            color     = "#7D6608"
            fontsize  = 10
        ]
    }

    /* === INTEGRATION - LE-JD ============================================= */

    subgraph cluster_integration {
        label     = "Integration  -  Latent Engagement Joint Display (LE-JD)"
        style     = filled
        fillcolor = "#F4ECF7"
        color     = "#6C3483"
        penwidth  = 2
        fontsize  = 13
        fontcolor = "#6C3483"

        dbn [
            label     = "Dynamic Bayesian Network (DBN)\n\n- Input: engagement_panel_weekly.csv\n- Models temporal dependencies and\n  engagement-state transitions\n- Identifies structural patterns\n  and engagement trajectories\n- Addresses RQ1 and RQ2"
            fillcolor = "#F4ECF7"
            color     = "#6C3483"
        ]

        lejd [
            label     = "LE-JD\nLatent Engagement Joint Display\n\nConvergent integration of 4 artifacts:\n  engagement_panel_weekly.csv   (quantitative)\n  student_personas.csv          (persona profiles)\n  llm_survey_responses.csv      (qualitative strand)\n  persona_enrollment_bridge.csv (alignment layer)\n\nAligns: behavioral indicators +\n  latent engagement states +\n  qualitative mechanisms +\n  meta-inferences\n\nAnswers: RQ1  RQ2  RQ3  RQ4"
            shape     = doubleoctagon
            fillcolor = "#E8DAEF"
            color     = "#6C3483"
            penwidth  = 3
            fontsize  = 11
        ]
    }

    /* === EDGES - Pipeline P ============================================== */

    proposal -> P0 [label=" drives requirements" color="#2471A3" style=dashed]

    studentVle        -> P0 [color="#1E8449" style=dotted]
    studentInfo       -> P0 [color="#1E8449" style=dotted]
    studentAssessment -> P0 [color="#1E8449" style=dotted]
    assessments_csv   -> P0 [color="#1E8449" style=dotted]
    courses_csv       -> P0 [color="#1E8449" style=dotted]

    P0 -> P1 [label=" setup OK"]

    studentVle        -> P1 [color="#1E8449"]
    studentInfo       -> P1 [color="#1E8449"]
    studentAssessment -> P1 [color="#1E8449"]
    assessments_csv   -> P1 [color="#1E8449"]
    courses_csv       -> P1 [color="#1E8449"]

    P1 -> duckdb [label=" 5 raw tables"]
    duckdb -> P2   [label=" raw_student_vle, raw_courses"]
    P2 -> duckdb   [label=" panel_base"]
    duckdb -> P3   [label=" panel_base"]
    P3 -> duckdb   [label=" panel_indicators"]
    duckdb -> P4   [label=" panel_indicators, raw_student_assessment, raw_assessments"]
    P4 -> duckdb   [label=" panel_with_assessment"]
    duckdb -> P5   [label=" panel_with_assessment, raw_student_info"]
    P5 -> duckdb   [label=" panel_with_demographics"]
    duckdb -> P6   [label=" panel_with_demographics"]
    P6 -> quant_csv [label=" 22 validated columns" color="#1E8449" penwidth=2]

    /* === EDGES - Pipeline S ============================================== */

    proposal -> S4 [label=" Q1-Q24 Appendix A" color="#7D6608" style=dashed]

    zenodo -> S0
    kaggle -> S0
    S0 -> S1 [label=" validated raw CSVs"]
    S1 -> S2 [label=" decoded + normalized"]
    S2 -> S3 [label=" persona_pairs.csv (1,300 pairs)"]
    S3 -> personas_csv [penwidth=2 color="#7D6608"]
    personas_csv -> S4
    S4 -> S5 [label=" 1,300 one-shot prompts"]
    S5 -> claude_api [label=" API call per persona" color="#C0392B"]
    claude_api -> S5 [label=" JSON Q1-Q24" color="#C0392B"]
    S5 -> llm_responses [penwidth=2 color="#7D6608"]

    /* === CROSS-PIPELINE EDGES ============================================ */

    quant_csv    -> S6 [label=" OULAD enrollments" color="#1E8449" penwidth=2]
    personas_csv -> S6 [label=" 1,300 profiles" color="#7D6608"]
    S6 -> bridge_csv [penwidth=2 color="#7D6608"]

    /* === EDGES - LE-JD Integration ======================================= */

    quant_csv     -> dbn  [label=" DBN input" color="#6C3483" penwidth=2]
    dbn           -> lejd [label=" patterns + trajectories" color="#6C3483" penwidth=2]
    llm_responses -> lejd [label=" qualitative mechanisms" color="#6C3483" penwidth=2]
    personas_csv  -> lejd [label=" profiles + archetypes" color="#6C3483" penwidth=2]
    bridge_csv    -> lejd [label=" persona-enrollment alignment" color="#6C3483" penwidth=2]
}
