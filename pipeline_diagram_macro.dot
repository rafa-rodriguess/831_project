/**
 * pipeline_diagram_macro.dot  -  MACRO VIEW
 * ==========================================
 * High-level overview of the research pipeline for the paper:
 *   "From Clicks to Constructs: A Mixed-Methods Framework for
 *    Modeling Latent Student Engagement Using OULAD Data"
 *
 * Each box represents a logical stage; individual .py scripts
 * are NOT shown here (see pipeline_diagram.dot for full detail).
 *
 * Render:
 *   dot -Tpng pipeline_diagram_macro.dot -o pipeline_diagram_macro.png
 *   dot -Tsvg pipeline_diagram_macro.dot -o pipeline_diagram_macro.svg
 */

digraph pipeline_macro {

    graph [
        rankdir   = TB
        fontname  = "Helvetica"
        fontsize  = 14
        splines   = polyline
        nodesep   = 0.80
        ranksep   = 0.90
        bgcolor   = "#FAFAFA"
        label     = "From Clicks to Constructs - Macro Pipeline Overview\n(OULAD Quantitative Strand  +  Synthetic Qualitative Strand  +  LE-JD Integration)"
        labelloc  = t
        labeljust = c
    ]

    node [
        fontname = "Helvetica"
        fontsize = 12
        style    = "filled,rounded"
        shape    = box
        margin   = "0.30,0.18"
    ]

    edge [
        fontname  = "Helvetica"
        fontsize  = 10
        color     = "#444444"
        arrowsize = 1.0
        penwidth  = 1.5
    ]

    /* ===================================================================
     *  ROOT
     * =================================================================== */

    proposal [
        label     = "Paper Proposal\n(proposal.md)\n\nResearch Problem + Design\n4 RQs  |  Appendix A: Q1-Q24\nConvergent Mixed-Methods"
        shape     = note
        fillcolor = "#EAF4FB"
        color     = "#2471A3"
        penwidth  = 2.5
        fontsize  = 12
    ]

    /* ===================================================================
     *  PIPELINE P - OULAD QUANTITATIVE STRAND
     * =================================================================== */

    subgraph cluster_P {
        label     = "Pipeline P  -  OULAD Quantitative Strand"
        style     = filled
        fillcolor = "#EBF5FB"
        color     = "#1A5276"
        penwidth  = 2.5
        fontsize  = 14
        fontcolor = "#1A5276"

        oulad_raw [
            label     = "OULAD Source Data\n(5 read-only CSVs)\n\nstudentVle / studentInfo\nstudentAssessment\nassessments / courses"
            fillcolor = "#D5F5E3"
            color     = "#1E8449"
            penwidth  = 2
        ]

        P_setup [
            label     = "Environment Setup\n(P0_foundation.py)\n\nValidate inputs, install packages,\ncreate directory tree,\ninitialise audit log"
            fillcolor = "#D6EAF8"
            color     = "#1A5276"
        ]

        P_ingest [
            label     = "Data Ingestion into DuckDB\n(P1_ingestion.py)\n\nLoad 5 CSVs into DuckDB\nValidate schemas + row counts\nPersist raw tables"
            fillcolor = "#D6EAF8"
            color     = "#1A5276"
        ]

        P_panel [
            label     = "Person x Week Panel Construction\n(P2 + P3)\n\nConvert clicks to weekly time-series\nDerive engagement indicators:\n  recency, streak, engagement_state"
            fillcolor = "#D6EAF8"
            color     = "#1A5276"
        ]

        P_enrich [
            label     = "Panel Enrichment\n(P4 + P5)\n\nJoin assessment scores + timeliness\nJoin student demographics\nValidate referential integrity"
            fillcolor = "#D6EAF8"
            color     = "#1A5276"
        ]

        P_export [
            label     = "Validated Export\n(P6_export.py)\n\nSelect 22 final columns\nFull data quality checks\nExport CSV + schema metadata"
            fillcolor = "#D6EAF8"
            color     = "#1A5276"
        ]

        quant_csv [
            label     = "engagement_panel_weekly.csv\n<Final Quantitative Dataset>\n\nPerson x Week  |  22 columns\nClickstream + Assessment\n+ Demographics + Engagement State"
            shape     = note
            fillcolor = "#A9DFBF"
            color     = "#1E8449"
            penwidth  = 2.5
            fontsize  = 12
        ]
    }

    /* ===================================================================
     *  PIPELINE S - SYNTHETIC QUALITATIVE STRAND
     * =================================================================== */

    subgraph cluster_S {
        label     = "Pipeline S  -  Synthetic Qualitative Strand"
        style     = filled
        fillcolor = "#FEF9E7"
        color     = "#7D6608"
        penwidth  = 2.5
        fontsize  = 14
        fontcolor = "#7D6608"

        ext_data [
            label     = "External Datasets\n(2 public sources)\n\nZenodo: 14,003 students\n(behavioral + academic)\nKaggle: 1,300 students\n(psychological constructs)"
            fillcolor = "#FEF5E7"
            color     = "#D68910"
            penwidth  = 2
        ]

        S_ingest_norm [
            label     = "Data Ingestion and Normalization\n(S0 + S1)\n\nDownload / validate raw files\nDecode label-encoded columns\nNormalize 6 bridge constructs to [0,1]:\n  attendance, assignment, exam,\n  motivation, stress, discussion"
            fillcolor = "#FEF9E7"
            color     = "#7D6608"
        ]

        S_cluster [
            label     = "Cross-Dataset Clustering and Matching\n(S2 - Cluster and Match)\n\nKMeans clustering per dataset\nNearest-neighbor matching\n(Kaggle -> Zenodo, 1-to-1)\n1,300 matched persona pairs"
            fillcolor = "#FEF9E7"
            color     = "#7D6608"
        ]

        S_personas [
            label     = "Synthetic Persona Assembly\n(S3 - Persona Assembly)\n\nMerge Kaggle + Zenodo per matched pair\nAssign 8 engagement archetypes\n(risk level x motivation x stress)\nstudent_personas.csv: 1,300 x 37"
            fillcolor = "#FEF9E7"
            color     = "#7D6608"
        ]

        personas_csv [
            label     = "student_personas.csv\n1,300 synthetic personas\n(full profile + archetype)"
            shape     = note
            fillcolor = "#FAD7A0"
            color     = "#7D6608"
            penwidth  = 2
        ]

        S_prompts [
            label     = "Interview Prompt Generation\n(S4 - Generate Prompts)\n\nEmbed Q1-Q24 from Appendix A\nacross 6 thematic domains\nAssign unique international name\nBuild one-shot Claude prompt"
            fillcolor = "#FEF9E7"
            color     = "#7D6608"
        ]

        S_llm [
            label     = "LLM Survey Execution\n(S5 - Run LLM Survey)\n\nAnthropic Claude API  |  1,300 calls\n5 parallel workers  |  resume-safe\nPersona answers Q1-Q24 in first person\nJSON schema validation per response"
            fillcolor = "#FADBD8"
            color     = "#922B21"
            penwidth  = 2.5
        ]

        claude_api [
            label     = "Anthropic Claude API\n(claude-opus-4-5)\n\nSimulates student semi-structured\ninterviews in first person\n1,300 personas x 24 questions"
            shape     = component
            fillcolor = "#FDEDEC"
            color     = "#C0392B"
            penwidth  = 2
        ]

        llm_responses [
            label     = "llm_survey_responses.csv\n+  1,300 JSON files\n\nFull qualitative evidence strand:\nQ1-Q24 answers per persona"
            shape     = note
            fillcolor = "#FAD7A0"
            color     = "#7D6608"
            penwidth  = 2
        ]

        S_bridge [
            label     = "Persona-Enrollment Alignment\n(S6 - Enrollment Bridge)\n\nLink each persona to up to 10\nmatching OULAD enrollments\nWeighted similarity score (gender,\nresult, engagement, exam, activity)\npersona_enrollment_bridge.csv"
            fillcolor = "#FEF9E7"
            color     = "#7D6608"
        ]

        bridge_csv [
            label     = "persona_enrollment_bridge.csv\n(persona <-> enrollment mapping\nwith similarity scores)"
            shape     = note
            fillcolor = "#FAD7A0"
            color     = "#7D6608"
            penwidth  = 2
        ]
    }

    /* ===================================================================
     *  INTEGRATION
     * =================================================================== */

    subgraph cluster_integration {
        label     = "Integration  -  Convergent Mixed-Methods Analysis"
        style     = filled
        fillcolor = "#F4ECF7"
        color     = "#6C3483"
        penwidth  = 2.5
        fontsize  = 14
        fontcolor = "#6C3483"

        dbn [
            label     = "Probabilistic Temporal Modeling\n(Dynamic Bayesian Network)\n\nModel engagement as latent construct\nover time using DBN\nIdentify trajectories + structural\npatterns  (addresses RQ1, RQ2)"
            fillcolor = "#F4ECF7"
            color     = "#6C3483"
            penwidth  = 2
        ]

        lejd [
            label     = "LE-JD\nLatent Engagement Joint Display\n\nConvergent integration:\n  Quantitative patterns (DBN)\n  Qualitative mechanisms (LLM)\n  Persona profiles + archetypes\n  Behavioral-qualitative alignment\n\nFinal analytical artifact\nAddresses RQ1 + RQ2 + RQ3 + RQ4"
            shape     = doubleoctagon
            fillcolor = "#E8DAEF"
            color     = "#6C3483"
            penwidth  = 3.5
            fontsize  = 12
        ]
    }

    /* ===================================================================
     *  EDGES
     * =================================================================== */

    /* proposal anchors */
    proposal -> P_setup   [label=" drives requirements" color="#2471A3" style=dashed penwidth=1.5]
    proposal -> S_prompts [label=" Q1-Q24 Appendix A" color="#7D6608" style=dashed penwidth=1.5]

    /* Pipeline P */
    oulad_raw  -> P_setup  [color="#1E8449"]
    P_setup    -> P_ingest [label=" environment ready"]
    oulad_raw  -> P_ingest [color="#1E8449"]
    P_ingest   -> P_panel  [label=" 5 raw tables in DuckDB"]
    P_panel    -> P_enrich [label=" panel_base + panel_indicators"]
    P_enrich   -> P_export [label=" panel with assessment + demographics"]
    P_export   -> quant_csv [label=" 22 validated columns" color="#1E8449" penwidth=2.5]

    /* Pipeline S */
    ext_data      -> S_ingest_norm [color="#D68910"]
    S_ingest_norm -> S_cluster     [label=" decoded + normalized"]
    S_cluster     -> S_personas    [label=" 1,300 matched pairs"]
    S_personas    -> personas_csv  [penwidth=2.5 color="#7D6608"]
    personas_csv  -> S_prompts
    S_prompts     -> S_llm         [label=" 1,300 one-shot prompts"]
    S_llm         -> claude_api    [label=" API call per persona" color="#C0392B"]
    claude_api    -> S_llm         [label=" JSON responses" color="#C0392B"]
    S_llm         -> llm_responses [penwidth=2.5 color="#7D6608"]

    /* Cross-pipeline bridge */
    quant_csv    -> S_bridge [label=" OULAD enrollment data" color="#1E8449" penwidth=2.5]
    personas_csv -> S_bridge [label=" 1,300 personas" color="#7D6608"]
    S_bridge     -> bridge_csv [penwidth=2.5 color="#7D6608"]

    /* LE-JD Integration */
    quant_csv     -> dbn  [label=" quantitative panel" color="#6C3483" penwidth=2.5]
    dbn           -> lejd [label=" engagement patterns + trajectories" color="#6C3483" penwidth=2.5]
    llm_responses -> lejd [label=" qualitative mechanisms (RQ3)" color="#6C3483" penwidth=2.5]
    personas_csv  -> lejd [label=" persona archetypes (RQ3)" color="#6C3483" penwidth=2.5]
    bridge_csv    -> lejd [label=" behavioral-qualitative alignment (RQ4)" color="#6C3483" penwidth=2.5]
}
